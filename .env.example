# Postgres DSN — use the Supabase session pooler (port 5432) or direct connection.
# The MCP server bypasses RLS by design: it's the Cowork channel and trusts the
# admin_worker_id below for attribution/audit.
WIMA_DB_DSN=postgresql://postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# admin_worker.id that every MCP tool call is attributed to in audit_log,
# pipeline_event.admin_worker_id, draft.created_by_admin_id, etc.
# This is NOT auth.users.id — it's admin_worker.id (the internal row).
WIMA_ADMIN_WORKER_ID=87e604e4-36d8-4f06-b86c-615d3cd1ade5

# Tool call log level: DEBUG, INFO, WARNING
WIMA_LOG_LEVEL=INFO

# --- File download tools (download_upload / download_task_uploads /
#     get_upload_signed_url / list_workspace_files) ---

# Supabase project URL (no trailing slash).
WIMA_SUPABASE_URL=https://PROJECT.supabase.co

# service_role key (Supabase Studio → Project Settings → API → service_role).
# REQUIRED only for the four download/signed-URL tools. Without it, those
# tools raise UPSTREAM_ERROR but every other tool keeps working.
# NEVER ship this in a client-side bundle.
WIMA_SUPABASE_SERVICE_KEY=

# Bucket that holds client uploads. Matches SCHEMA_SUPABASE.md §5.
WIMA_DOCUMENTS_BUCKET=documents

# Where downloads land on your laptop. Default: ~/.wima-cowork/workspace
# Layout mirrors storage: <WIMA_WORKSPACE_DIR>/<project_id>/<filename>.
WIMA_WORKSPACE_DIR=~/.wima-cowork/workspace
